{
	"format_version":"1.10.0",
	"particle_effect":{
		"description":{
			"identifier":"ra:navigation_ring",
			"basic_render_parameters":{
				"material":"particles_blend",
				"texture":"textures/particles/ra_navigation_ring"
			}
		},
		"components":{
			"minecraft:emitter_rate_instant":{
				"num_particles":1
			},
			"minecraft:emitter_lifetime_once":{
				"active_time":1
			},
			"minecraft:particle_lifetime_expression": {
        "max_lifetime":1.01
      },
			"minecraft:emitter_local_space":{
				"position":true,
				"rotation":false
			},
			"minecraft:particle_motion_parametric":{
				"relative_position":[0,-1.4,0],
				"direction":[0,0,-1],
				"rotation": "math.atan2((v.ra_navigation_ring_x ?? 0) - q.position(0), (v.ra_navigation_ring_z ?? 0) - q.position(2))"
				//3.The data received from "pre_effect_script" is reflected here.
			},
			"minecraft:particle_appearance_billboard":{
				"size":[1.2,1.2],
				"facing_camera_mode":"direction_y"
			},
			"minecraft:particle_appearance_tinting":{
				"color":[1,1,1,1]
			}
		}
	}
}